{
  "expo": {
    "name": "Exeggutor Mobile",
    "slug": "exeggutor-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "exeggutor",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.exeggutor.mobile",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Exeggutor uses speech recognition to convert your voice into terminal commands.",
        "NSMicrophoneUsageDescription": "Exeggutor needs microphone access for voice input mode."
      }
    },
    "android": {
      "package": "com.exeggutor.mobile",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-speech-recognition"
    ]
  }
}
